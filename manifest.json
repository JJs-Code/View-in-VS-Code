{
  "manifest_version": 3,
  "name": "GitHub View in VS Code",
  "version": "1.0",

  "permissions": [
    "contextMenus",
    "declarativeContent",
    "tabs"
  ],

  "host_permissions": [
    "https://github.com/*",
    "https://github.dev/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://github.com/*",
        "https://github.dev/*"
      ],
      "js": ["theme-detector.js"]
    },
    {
      "matches": ["https://github.dev/*"],
      "js":      ["back-button.js"],
      "css":     ["back-button.css"]
    }
  ],

  "icons": {
    "16":  "icons/VS Code 16x16.png",
    "32":  "icons/VS Code 32x32.png",
    "128": "icons/VS Code 128x128.png"
  },

  "action": {
    "default_title": "View in VS Code"
  }
}
